{
  "compilerOptions": {
    "target": "ES2016",
    "module": "CommonJS",
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "js-yaml"] // Explicitly include types
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}